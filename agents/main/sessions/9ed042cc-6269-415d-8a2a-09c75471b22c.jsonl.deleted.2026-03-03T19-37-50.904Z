{"type":"message","id":"04e06100","parentId":"9a261d98","timestamp":"2026-03-02T19:33:55.186Z","message":{"role":"assistant","content":[{"type":"text","text":"现在我看到polymarket-paper目录存在，让我先查看cli.py文件，了解scan命令的功能。\n\n"},{"type":"toolCall","id":"call_73bf061c96b6404eba72b513","name":"read","arguments":{"path":"/home/ubuntu/.openclaw/workspace/polymarket-paper/cli.py"}}],"api":"openai-completions","provider":"bailian","model":"qwen3-max-2026-01-23","usage":{"input":11560,"output":53,"cacheRead":0,"cacheWrite":0,"totalTokens":11613,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772480032286}}
{"type":"message","id":"af138c1e","parentId":"04e06100","timestamp":"2026-03-02T19:33:55.194Z","message":{"role":"toolResult","toolCallId":"call_73bf061c96b6404eba72b513","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nPolymarket 模拟交易 CLI\n\"\"\"\n\nimport sys\nimport json\nimport argparse\nfrom pathlib import Path\n\n# 添加到路径\nsys.path.insert(0, str(Path(__file__).parent))\n\nfrom paper_trading import PaperTradingSystem, StrategyEngine\nfrom markets import PolymarketClient, scan_opportunities_sync\n\n\ndef cmd_scan(args):\n    \"\"\"扫描市场机会\"\"\"\n    print(\"🔍 扫描 Polymarket 市场机会...\")\n    \n    # 加载系统\n    system = PaperTradingSystem()\n    strategy_engine = StrategyEngine(system.config)\n    client = PolymarketClient()\n    \n    # 扫描\n    opportunities = scan_opportunities_sync(client, strategy_engine)\n    \n    if not opportunities:\n        print(\"❌ 未发现符合条件的交易机会\")\n        return 0\n    \n    print(f\"\\n✅ 发现 {len(opportunities)} 个机会:\\n\")\n    for i, opp in enumerate(opportunities[:10], 1):\n        print(f\"{i}. {opp['question'][:60]}...\")\n        print(f\"   策略: {opp['strategy']} | 概率: {opp['probability']:.0%} | 推荐: {opp['recommendation']}\")\n        print(f\"   金额: ${opp['amount']} | 当前价格: ${opp['entry_price']:.2f}\")\n        print()\n    \n    # 保存机会\n    if args.save:\n        with open(system.data_dir / \"opportunities.json\", \"w\") as f:\n            json.dump(opportunities, f, indent=2)\n        print(f\"💾 机会已保存\")\n    \n    return 0\n\n\ndef cmd_performance(args):\n    \"\"\"查看绩效\"\"\"\n    system = PaperTradingSystem()\n    perf = system.get_performance()\n    \n    print(\"=\" * 50)\n    print(\"📊 Polymarket 模拟交易绩效\")\n    print(\"=\" * 50)\n    print(f\"💰 当前资本: ${perf['capital']:,.2f}\")\n    print(f\"📈 总交易数: {perf['total_trades']}\")\n    print(f\"✅ 胜率: {perf['win_rate']:.1f}%\")\n    print(f\"💵 总盈亏: ${perf['total_pnl']:,.2f}\")\n    print(f\"📊 盈利因子: {perf['profit_factor']:.2f}\")\n    print(f\"🔓 开仓中: {perf['open_positions']} 笔\")\n    print(\"=\" * 50)\n    \n    if perf.get(\"trades\"):\n        print(\"\\n📜 最近交易:\")\n        for t in perf[\"trades\"]:\n            pnl_str = f\"+${t['pnl']:.2f}\" if t['pnl'] > 0 else f\"-${abs(t['pnl']):.2f}\"\n            print(f\"  {t['position']} | {t['question'][:40]}... | {pnl_str}\")\n    \n    return 0\n\n\ndef cmd_open(args):\n    \"\"\"开仓\"\"\"\n    system = PaperTradingSystem()\n    \n    if args.amount > system.capital:\n        print(f\"❌ 余额不足，当前: ${system.capital:.2f}\")\n        return 1\n    \n    trade = system.open_position(\n        market_id=args.market_id,\n        question=args.question,\n        position=args.position,\n        price=args.price,\n        amount=args.amount\n    )\n    \n    print(f\"✅ 开仓成功!\")\n    print(f\"  ID: {trade.trade_id}\")\n    print(f\"  品种: {trade.position}\")\n    print(f\"  价格: ${trade.entry_price:.2f}\")\n    print(f\"  金额: ${trade.amount}\")\n    \n    return 0\n\n\ndef cmd_close(args):\n    \"\"\"平仓\"\"\"\n    system = PaperTradingSystem()\n    \n    trade = system.close_position(args.trade_id, args.price)\n    \n    if trade:\n        pnl_str = f\"+${trade.pnl:.2f}\" if trade.pnl > 0 else f\"-${abs(trade.pnl):.2f}\"\n        print(f\"✅ 平仓成功! 盈亏: {pnl_str}\")\n    else:\n        print(\"❌ 未找到对应交易\")\n        return 1\n    \n    return 0\n\n\ndef cmd_reset(args):\n    \"\"\"重置\"\"\"\n    system = PaperTradingSystem()\n    print(system.reset())\n    return 0\n\n\ndef cmd_test(args):\n    \"\"\"测试市场连接\"\"\"\n    print(\"🧪 测试 Polymarket API...\")\n    client = PolymarketClient()\n    markets = client.get_markets(limit=5)\n    \n    if markets:\n        print(f\"✅ 成功获取 {len(markets)} 个市场\\n\")\n        for m in markets[:3]:\n            formatted = client.format_market(m)\n            print(f\"📌 {formatted.get('question', 'N/A')[:50]}\")\n            print(f\"   YES: ${formatted.get('yes_price'):.2f} | NO: ${formatted.get('no_price'):.2f}\")\n            print(f\"   24h成交量: ${formatted.get('volume24hr', 0):,.0f}\")\n            print()\n    else:\n        print(\"❌ 无法获取市场数据\")\n        return 1\n    \n    return 0\n\n\ndef main():\n    parser = argparse.ArgumentParser(description=\"Polymarket 模拟交易\")\n    subparsers = parser.add_subparsers(dest=\"command\")\n    \n    # test\n    subparsers.add_parser(\"test\", help=\"测试API连接\")\n    \n    # scan\n    scan_parser = subparsers.add_parser(\"scan\", help=\"扫描市场机会\")\n    scan_parser.add_argument(\"--save\", action=\"store_true\", help=\"保存机会\")\n    \n    # performance\n    subparsers.add_parser(\"performance\", help=\"查看绩效\")\n    \n    # open\n    open_parser = subparsers.add_parser(\"open\", help=\"开仓\")\n    open_parser.add_argument(\"market_id\")\n    open_parser.add_argument(\"question\")\n    open_parser.add_argument(\"position\", choices=[\"YES\", \"NO\"])\n    open_parser.add_argument(\"price\", type=float)\n    open_parser.add_argument(\"amount\", type=float)\n    \n    # close\n    close_parser = subparsers.add_parser(\"close\", help=\"平仓\")\n    close_parser.add_argument(\"trade_id\")\n    close_parser.add_argument(\"price\", type=float)\n    \n    # reset\n    subparsers.add_parser(\"reset\", help=\"重置模拟交易\")\n    \n    args = parser.parse_args()\n    \n    if args.command == \"test\":\n        return cmd_test(args)\n    elif args.command == \"scan\":\n        return cmd_scan(args)\n    elif args.command == \"performance\":\n        return cmd_performance(args)\n    elif args.command == \"open\":\n        return cmd_open(args)\n    elif args.command == \"close\":\n        return cmd_close(args)\n    elif args.command == \"reset\":\n        return cmd_reset(args)\n    else:\n        parser.print_help()\n        return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())"}],"isError":false,"timestamp":1772480035191}}
